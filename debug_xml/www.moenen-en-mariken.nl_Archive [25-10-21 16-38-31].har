          "content": {
            "mimeType": "text/css",
            "size": 8996,
            "text": "@font-face{font-family:logoFont;src:url(../fonts/frms421n.ttf)}h1,h2,h3,h4,p,li,div,a,form{color:white;font-family:myriad pro,sans-serif}ul{list-style:none;margin-left:0}body{background:url(\"../img/bg.jpg\");background-attachment:fixed;background-size:cover;background-position:center}.bodyWrapper{background:rgba(13,83,94,0.88);background-size:cover}#content{min-height:64vh}header{margin-bottom:40px}.logo{padding:30px 0 10px}.logo h1,.logo span{font-family:logoFont}.logo span{font-size:1.3rem;margin-left:5px}.navLinks{padding:5px 0;background-color:#ff6700;border-radius:18px;-webkit-box-shadow:2px 3px 10px 0 rgba(0,0,0,0.55);-moz-box-shadow:2px 3px 10px 0 rgba(0,0,0,0.55);box-shadow:2px 3px 10px 0 rgba(0,0,0,0.55);position:relative}.navLinks li{display:inline-block;margin:0 20px;padding-bottom:0;padding-top:1px}.navLinks li a:hover{color:#262626}li.fbIcon{font-weight:600;font-size:1.2em;position:relative;bottom:-0.3ex}.mandjeIcon{background:#262626;width:3em;border-radius:.9em;position:absolute;right:5px;top:6px;border:2px solid #262626;height:1.85em}.mandjeIcon:hover{border:2px solid white}.mandjeImg{height:1.30em;width:auto;position:relative}.navLinks li.selected a{color:#262626}.mandjeIcon.selected{border:2px solid white;height:1.85em}section{margin-bottom:60px}section.newHeader{margin-bottom:50px}h2{font-size:1.4rem}h3{font-size:1.2rem;color:#ff931e}h4{font-size:1.1rem}.single-item{width:99%;margin:auto;border-radius:15px;background:rgba(28,28,28,0.35)}.single-item img{margin:auto;padding:15px;width:100%;height:auto}.variable-width{border-radius:15px;background:rgba(28,28,28,0.35)}.multiple-items{background:rgba(28,28,28,0.35);border-radius:15px;padding-left:40px}.multiple-items .product{border:0}.multiple-items a{width:150px;height:150px;overflow:hidden;display:block;padding:10px;background:white;border-radius:10px;margin:auto}.multiple-items a img{width:100%;height:100%}.multiple-items .slideBasket a{display:block;text-align:center;width:4